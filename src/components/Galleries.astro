---
import { ListObjectsV2Command, S3Client } from "@aws-sdk/client-s3";

// 1. Try Native R2
let bucket: any = null;
const runtime = Astro.locals.runtime;
if (runtime) {
  try { bucket = runtime.env?.BUCKET || runtime.BUCKET; } catch(err) {}
}

let dynamicGalleries = [];

if (bucket) {
  try {
    const list = await bucket.list({ delimiter: '/' });
    dynamicGalleries = (list.commonPrefixes || [])
      .map((prefix: string) => {
        const name = prefix.replace('/', '');
        if (['api', 'manga-covers', 'covers', 'video'].includes(name.toLowerCase())) return null;
        return {
          name: name.charAt(0).toUpperCase() + name.slice(1),
          count: 'Gallery',
          color: name.toLowerCase() === 'maria' ? '#ff4d6d' : '#9d4edd'
        };
      })
      .filter(Boolean);
  } catch (err) {
    console.error('Native R2 List Error:', err);
  }
}

// 2. S3 Fallback (if native failed or yielded nothing relevant)
if (dynamicGalleries.length === 0) {
    const env = runtime?.env || (globalThis as any).process?.env || {};
    const accessKeyId = env.R2_ACCESS_KEY_ID;
    const secretAccessKey = env.R2_SECRET_ACCESS_KEY;
    const endpoint = env.R2_ENDPOINT;
    const bucketName = env.R2_BUCKET_NAME || 'media';

    if (accessKeyId && secretAccessKey && endpoint) {
        try {
            const s3 = new S3Client({
                region: "auto",
                endpoint: endpoint,
                credentials: { accessKeyId, secretAccessKey },
            });

            const command = new ListObjectsV2Command({
                Bucket: bucketName,
                Delimiter: '/'
            });

            const response = await s3.send(command);
            dynamicGalleries = (response.CommonPrefixes || [])
                .map((p: any) => {
                    const name = p.Prefix.replace('/', '');
                    if (['api', 'manga-covers', 'covers', 'video'].includes(name.toLowerCase())) return null;
                    return {
                        name: name.charAt(0).toUpperCase() + name.slice(1),
                        count: 'R2 S3',
                        color: name.toLowerCase() === 'maria' ? '#ff4d6d' : '#9d4edd'
                    };
                })
                .filter(Boolean);
        } catch (e) {
            console.error('S3 Fallback List Error:', e);
        }
    }
}

const defaultGalleries = [
  { name: 'Selfies', count: 124, color: '#9d4edd' },
  { name: 'Vacation', count: 45, color: '#7b2cbf' },
  { name: 'Party', count: 82, color: '#5a189a' },
];

const galleries = dynamicGalleries.length > 0 ? dynamicGalleries : [
  { name: 'Maria', count: 'Active', color: '#ff4d6d' },
  ...defaultGalleries
];
---

<section class="container" id="galleries">
  <div class="section-title-wrap">
    <h2>Galleries</h2>
    <p class="section-desc">Private visual collections stored in R2</p>
  </div>
  
  <div class="circles-grid">
    {galleries.map(gallery => (
      <a href={`/gallery/${gallery.name.toLowerCase()}`} class="circle-item">
        <div class="circle-wrapper" style={`background: linear-gradient(135deg, ${gallery.color}, #000);`}>
          <span>{gallery.name[0]}</span>
        </div>
        <div class="circle-info">
          <h3>{gallery.name}</h3>
          <p>{gallery.count}</p>
        </div>
      </a>
    ))}
  </div>
</section>

<style>
  .container {
    max-width: 1400px;
    margin: 40px auto;
    padding: 0 20px;
  }

  .section-title-wrap {
    margin-bottom: 25px;
  }

  .section-title-wrap h2 {
    font-size: 1.8rem;
    font-weight: 800;
    margin: 0;
  }

  .section-desc {
    color: #666;
    font-size: 0.9rem;
    margin-top: 4px;
  }

  .circles-grid {
    display: flex;
    gap: 30px;
    overflow-x: auto;
    padding: 10px 5px 25px;
    scrollbar-width: thin;
    scrollbar-color: var(--accent-color) transparent;
  }

  .circle-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 15px;
    min-width: 120px;
    text-decoration: none;
    transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .circle-item:hover {
    transform: translateY(-10px);
  }

  .circle-wrapper {
    width: 110px;
    height: 110px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 3px solid #222;
    box-shadow: 0 8px 16px rgba(0,0,0,0.6);
    font-size: 36px;
    font-weight: 800;
    color: #fff;
    transition: all 0.3s;
    position: relative;
  }

  .circle-wrapper::after {
    content: '';
    position: absolute;
    inset: -6px;
    border-radius: 50%;
    border: 2px solid transparent;
    transition: all 0.3s;
  }

  .circle-item:hover .circle-wrapper {
    border-color: var(--accent-color);
    box-shadow: 0 0 25px rgba(157, 78, 221, 0.5);
  }

  .circle-item:hover .circle-wrapper::after {
    border-color: rgba(157, 78, 221, 0.3);
    inset: -10px;
  }

  .circle-info {
    text-align: center;
  }

  .circle-info h3 {
    font-size: 15px;
    font-weight: 700;
    color: #fff;
    margin: 0;
  }

  .circle-info p {
    font-size: 11px;
    color: #888;
    margin-top: 4px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
</style>
