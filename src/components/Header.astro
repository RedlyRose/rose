---
---
<header class="main-header">
  <div class="container header-content">
    <div class="header-left">
      <a href="/" class="logo">
        Vault<span>HUB</span>
      </a>
      <nav class="main-nav">
        <a href="/" class="nav-item">Videos</a>
        <a href="/manga" class="nav-item">Manga</a>
        <a href="/#galleries" class="nav-item">Galleries</a>
      </nav>
    </div>

    <div class="search-bar">
      <input type="text" placeholder="Search your private collection..." />
      <button type="button">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
      </button>
    </div>

    <nav class="nav-links">
      <a href="/upload" class="upload-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v4"></path><polyline points="17 8 12 3 7 8"></polyline><line x1="12" y1="3" x2="12" y2="15"></line></svg>
        Upload
      </a>
      <div class="profile-icon">
        <div class="avatar"></div>
      </div>
    </nav>
  </div>
</header>

<style>
  .main-header {
    background-color: var(--header-bg);
    border-bottom: 1px solid var(--border-color);
    padding: 12px 0;
    position: sticky;
    top: 0;
    z-index: 1000;
  }

  .header-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  .header-left {
    display: flex;
    align-items: center;
    gap: 30px;
  }

  .main-nav {
    display: flex;
    gap: 20px;
  }

  .nav-item {
    font-size: 15px;
    font-weight: 600;
    color: var(--text-muted);
    transition: color 0.2s;
  }

  .nav-item:hover {
    color: var(--accent-color);
  }

  .logo {
    font-size: 24px;
    font-weight: 900;
    letter-spacing: -1px;
    display: flex;
    align-items: center;
  }

  .logo span {
    background-color: var(--accent-color);
    color: #fff;
    padding: 2px 6px;
    border-radius: 4px;
    margin-left: 4px;
    font-weight: 800;
  }

  .search-bar {
    flex: 1;
    max-width: 400px;
    display: flex;
    background-color: #111;
    border: 1px solid var(--border-color);
    border-radius: 4px;
    overflow: hidden;
  }

  .search-bar input {
    flex: 1;
    background: transparent;
    border: none;
    padding: 10px 15px;
    color: #fff;
    font-size: 14px;
    outline: none;
  }

  .search-bar button {
    background-color: var(--border-color);
    padding: 0 15px;
    transition: background 0.2s;
  }

  .search-bar button:hover {
    background-color: var(--accent-color);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .upload-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    background-color: var(--accent-color);
    padding: 8px 16px;
    border-radius: 4px;
    font-weight: 600;
    font-size: 14px;
    transition: background 0.2s;
  }

  .upload-btn:hover {
    background-color: var(--accent-hover);
  }

  .avatar {
    width: 32px;
    height: 32px;
    background-color: var(--secondary-bg);
    border-radius: 50%;
    border: 1px solid var(--border-color);
  }

  @media (max-width: 768px) {
    .search-bar, .main-nav {
      display: none;
    }
  }
</style>
