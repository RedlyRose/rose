---
interface Props {
  currentVideoId?: string;
  limit?: number;
}

const { currentVideoId, limit = 10 } = Astro.props;

// Mock data for side videos
const sideVideos = [
  { id: '1', title: 'Related Content #1', duration: '12:45', views: '1.2K', thumb: 'https://images.unsplash.com/photo-1536240478700-b869070f9279?q=80&w=400' },
  { id: '2', title: 'Top Pick for You', duration: '05:20', views: '450', thumb: 'https://images.unsplash.com/photo-1516245834210-c4c142787335?q=80&w=400' },
  { id: '3', title: 'Coming Up Next', duration: '24:10', views: '3.5K', thumb: 'https://images.unsplash.com/photo-1551033481-99933583ca4d?q=80&w=400' },
  { id: '4', title: 'Weekend Special', duration: '08:15', views: '890', thumb: 'https://images.unsplash.com/photo-1518770660439-4636190af475?q=80&w=400' },
].filter(v => v.id !== currentVideoId).slice(0, limit);
---

<div class="side-videos">
  {sideVideos.map(video => (
    <a href={`/video/${video.id}`} class="side-video-card">
      <div class="side-thumb">
        <img src={video.thumb} alt={video.title} loading="lazy" />
        <span class="duration">{video.duration}</span>
      </div>
      <div class="side-info">
        <h4 class="side-title">{video.title}</h4>
        <div class="side-meta">
          <span>{video.views} views</span>
        </div>
      </div>
    </a>
  ))}
</div>

<style>
  .side-videos {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .side-video-card {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 10px;
  }

  .side-thumb {
    position: relative;
    aspect-ratio: 16/9;
    border-radius: 4px;
    overflow: hidden;
    background: #000;
  }

  .side-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .side-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .side-title {
    font-size: 14px;
    font-weight: 600;
    line-height: 1.2;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .side-meta {
    font-size: 12px;
    color: var(--text-muted);
  }

  .duration {
    position: absolute;
    bottom: 4px;
    right: 4px;
    background: rgba(0,0,0,0.8);
    padding: 1px 4px;
    border-radius: 2px;
    font-size: 10px;
    font-weight: 700;
  }

  .side-video-card:hover .side-title {
    color: var(--accent-color);
  }
</style>
