---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout title="VaultHUB | R2 File Manager">
  <Header />

  <main class="manager-container">
    <div class="sidebar">
      <div class="sidebar-header">
         <h2>R2 <span class="accent">Vault</span></h2>
      </div>
      
      <div class="nav-section">
        <button class="nav-btn active" data-path="">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
          Root Directory
        </button>
        <button class="nav-btn" data-path="covers/manga">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
          Manga Covers
        </button>
        <button class="nav-btn" data-path="maria">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
          Maria Gallery
        </button>
        <button class="nav-btn" data-path="video">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="23 7 16 12 23 17 23 7"></polygon><rect x="1" y="5" width="15" height="14" rx="2" ry="2"></rect></svg>
          Video Assets
        </button>
      </div>

      <div class="stats-card">
        <p>Storage Used</p>
        <div class="progress-bar"><div class="fill" style="width: 12%;"></div></div>
        <span class="byte-count">1.4 GB / Unlimited</span>
      </div>
    </div>

    <div class="workspace">
      <div class="workspace-header">
        <div class="breadcrumb-bar" id="breadcrumb">
          Vault / <span class="current">Root</span>
        </div>
        <div class="actions">
          <label class="upload-trigger">
            <input type="file" id="fileInput" multiple hidden />
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="17 8 12 3 7 8"></polyline><line x1="12" y1="3" x2="12" y2="15"></line></svg>
            Upload Files
          </label>
        </div>
      </div>

      <div class="file-grid" id="fileGrid">
        <!-- Files will be injected here -->
         <div class="loader">Scanning R2 Bucket...</div>
      </div>
    </div>
  </main>
</Layout>

<style>
  .manager-container {
    display: flex;
    height: calc(100vh - 72px);
    margin-top: 72px;
    background: #080808;
  }

  /* --- SIDEBAR --- */
  .sidebar {
    width: 250px;
    background: #0c0c0c;
    border-right: 1px solid rgba(255, 255, 255, 0.05);
    padding: 30px 15px;
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  .sidebar-header h2 {
    font-size: 1.2rem;
    margin: 0 0 10px 10px;
  }

  .accent { color: var(--accent-color); }

  .nav-section { display: flex; flex-direction: column; gap: 5px; }

  .nav-btn {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 15px;
    background: transparent;
    border: none;
    color: #888;
    border-radius: 8px;
    cursor: pointer;
    font-size: 0.9rem;
    font-weight: 600;
    transition: all 0.2s;
    text-align: left;
  }

  .nav-btn:hover { background: rgba(255, 255, 255, 0.03); color: #fff; }
  .nav-btn.active { background: rgba(157, 78, 221, 0.1); color: var(--accent-color); }

  .stats-card {
    margin-top: auto;
    background: #151515;
    padding: 20px;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .stats-card p { font-size: 11px; text-transform: uppercase; color: #555; font-weight: 800; margin-bottom: 10px; }
  .progress-bar { height: 4px; background: #222; border-radius: 2px; margin-bottom: 8px; }
  .progress-bar .fill { height: 100%; background: var(--accent-color); border-radius: 2px; }
  .byte-count { font-size: 11px; color: #888; }

  /* --- WORKSPACE --- */
  .workspace { flex: 1; padding: 30px; overflow-y: auto; }

  .workspace-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 30px;
  }

  .breadcrumb-bar { font-size: 0.9rem; color: #555; }
  .breadcrumb-bar .current { color: #fff; font-weight: 700; }

  .upload-trigger {
    background: var(--accent-color);
    color: white;
    padding: 10px 20px;
    border-radius: 6px;
    font-size: 0.85rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    transition: 0.2s;
  }

  .upload-trigger:hover { filter: brightness(1.2); transform: translateY(-2px); }

  .file-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 15px;
  }

  .loader { grid-column: 1 / -1; text-align: center; padding: 100px; color: #444; font-weight: 700; }

  /* --- FILE CARDS --- */
  .file-card {
    background: #111;
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 10px;
    padding: 10px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    transition: 0.2s;
    position: relative;
    group: file;
  }

  .file-card:hover { border-color: #333; background: #141414; }

  .preview-box {
    aspect-ratio: 1;
    background: #000;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    color: #444;
  }

  .preview-box img { width: 100%; height: 100%; object-fit: cover; }

  .file-info { display: flex; flex-direction: column; gap: 4px; }
  .file-name {
    font-size: 12px;
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    color: #eee;
  }
  .file-size { font-size: 10px; color: #555; }

  .delete-btn {
    position: absolute;
    top: 5px;
    right: 5px;
    background: rgba(255, 0, 0, 0.1);
    color: #ff4d4d;
    border: none;
    padding: 5px;
    border-radius: 4px;
    cursor: pointer;
    opacity: 0;
    transition: 0.2s;
  }

  .file-card:hover .delete-btn { opacity: 1; }
  .delete-btn:hover { background: #ff4d4d; color: white; }

  .folder-card { background: rgba(157, 78, 221, 0.05); border-color: rgba(157, 78, 221, 0.2); }
  .folder-icon { color: var(--accent-color); }
</style>

<script>
  let currentPath = '';
  const grid = document.getElementById('fileGrid');
  const breadcrumb = document.getElementById('breadcrumb');
  const navBtns = document.querySelectorAll('.nav-btn');
  const fileInput = document.getElementById('fileInput') as HTMLInputElement;

  async function loadFiles(path = '') {
    currentPath = path;
    grid!.innerHTML = '<div class="loader">Fetching R2 Data...</div>';
    breadcrumb!.innerHTML = `Vault / <span class="current">${path || 'Root'}</span>`;

    try {
      const res = await fetch(`/api/r2-manage?prefix=${path ? path + '/' : ''}`);
      const data = await res.json();

      grid!.innerHTML = '';

      // Render Folders
      data.folders.forEach((folder: string) => {
        const name = folder.split('/').filter(Boolean).pop();
        const card = document.createElement('div');
        card.className = 'file-card folder-card';
        card.innerHTML = `
          <div class="preview-box folder-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path></svg>
          </div>
          <div class="file-info">
            <span class="file-name">${name}</span>
          </div>
        `;
        card.onclick = () => loadFiles(folder.slice(0, -1));
        grid!.appendChild(card);
      });

      // Render Files
      data.files.forEach((file: any) => {
        const name = file.key.split('/').pop();
        const isImage = /\.(jpg|jpeg|png|webp|gif)$/i.test(name);
        const size = (file.size / 1024).toFixed(1) + ' KB';
        
        const card = document.createElement('div');
        card.className = 'file-card';
        card.innerHTML = `
          <div class="preview-box">
            ${isImage ? `<img src="${file.url}" loading="lazy" />` : `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"></path><polyline points="13 2 13 9 20 9"></polyline></svg>`}
          </div>
          <div class="file-info">
            <span class="file-name" title="${name}">${name}</span>
            <span class="file-size">${size}</span>
          </div>
          <button class="delete-btn" data-key="${file.key}">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
          </button>
        `;
        grid!.appendChild(card);
      });

    } catch (err) {
      grid!.innerHTML = '<div class="loader" style="color:#ff4d4d">Error loading files.</div>';
    }
  }

  // Navigation Logic
  navBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      navBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      loadFiles((btn as HTMLElement).dataset.path);
    });
  });

  // Action Delegation
  grid?.addEventListener('click', async (e) => {
    const target = e.target as HTMLElement;
    const deleteBtn = target.closest('.delete-btn') as HTMLElement;
    if (deleteBtn) {
      const key = deleteBtn.dataset.key;
      if (!confirm(`Permanently delete ${key}?`)) return;
      
      const res = await fetch('/api/r2-manage', {
        method: 'DELETE',
        body: JSON.stringify({ key })
      });
      if (res.ok) loadFiles(currentPath);
    }
  });

  // Upload Logic
  fileInput?.addEventListener('change', async () => {
    if (!fileInput.files?.length) return;
    
    // Simulate UI loading
    const status = document.createElement('div');
    status.className = 'loader';
    status.innerText = "Uploading...";
    grid?.prepend(status);

    for (const file of fileInput.files) {
      const formData = new FormData();
      formData.append('file', file);
      formData.append('path', currentPath);

      await fetch('/api/r2-manage', {
        method: 'POST',
        body: formData
      });
    }

    loadFiles(currentPath);
  });

  // Initial Load
  loadFiles();
</script>
