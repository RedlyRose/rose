---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';

const { id } = Astro.params;
const folder = id;

const env = Astro.locals.runtime?.env;
const bucket = env?.BUCKET;

let images = [];
if (bucket) {
  try {
    const list = await bucket.list({ prefix: `${folder}/` });
    images = (list.objects || [])
      .filter(obj => obj.key.match(/\.(jpg|jpeg|png|webp|gif)$/i))
      .map(obj => ({
        key: obj.key,
        url: `/api/content/${obj.key}`
      }));
  } catch (err) {
    console.error('R2 List Error:', err);
  }
}

// Fallback dummy data if empty
if (images.length === 0 && folder === 'maria') {
    images = Array.from({ length: 6 }).map((_, i) => ({
        key: `maria/sample-${i}.jpg`,
        url: `https://images.unsplash.com/photo-${1515150000000 + i * 1000}?q=80&w=800&auto=format&fit=crop`
    }));
}
---

<Layout title={`VaultHUB | ${folder?.toUpperCase()} Gallery`}>
  <Header />

  <main class="gallery-view">
    <div class="gallery-header">
      <div class="breadcrumb">
        <a href="/">Home</a> / <span class="current">Gallery</span>
      </div>
      <h1>{folder?.toUpperCase()} <span class="accent">Collection</span></h1>
      <p class="stats">{images.length} Photos Original Quality</p>
    </div>

    <div class="gallery-grid">
      {images.map((img) => (
        <div class="photo-card">
          <div class="photo-wrapper">
             <img src={img.url} alt={img.key} loading="lazy" />
             <div class="photo-actions">
                <a href={img.url} download class="action-bubble" title="Download">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                </a>
             </div>
          </div>
        </div>
      ))}
    </div>
  </main>
</Layout>

<style>
  .gallery-view {
    max-width: 1400px;
    margin: 0 auto;
    padding: 100px 20px 60px;
  }

  .gallery-header {
    margin-bottom: 40px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    padding-bottom: 20px;
  }

  .breadcrumb {
    font-size: 12px;
    color: #666;
    margin-bottom: 10px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .breadcrumb a {
    color: #888;
    text-decoration: none;
  }

  .breadcrumb a:hover { color: var(--accent-color); }

  .gallery-header h1 {
    font-size: 2.5rem;
    margin: 0;
    font-weight: 800;
  }

  .accent {
    color: var(--accent-color);
    text-shadow: 0 0 15px rgba(157, 78, 221, 0.4);
  }

  .stats {
    color: #888;
    margin-top: 5px;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 20px;
  }

  .photo-card {
    border-radius: 12px;
    overflow: hidden;
    background: #111;
    border: 1px solid rgba(255, 255, 255, 0.05);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .photo-card:hover {
    transform: translateY(-5px);
    border-color: var(--accent-color);
  }

  .photo-wrapper {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .photo-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .photo-card:hover .photo-wrapper img {
    transform: scale(1.05);
  }

  .photo-actions {
    position: absolute;
    bottom: 15px;
    right: 15px;
    display: flex;
    gap: 10px;
    opacity: 0;
    transform: translateY(10px);
    transition: all 0.3s;
  }

  .photo-card:hover .photo-actions {
    opacity: 1;
    transform: translateY(0);
  }

  .action-bubble {
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(5px);
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    text-decoration: none;
    border: 1px solid rgba(255, 255, 255, 0.1);
    transition: background 0.2s;
  }

  .action-bubble:hover {
    background: var(--accent-color);
  }

  @media (max-width: 768px) {
    .gallery-grid {
      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
      gap: 10px;
    }
  }
</style>
