---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import SideVideos from '../../components/SideVideos.astro';

// In a real app, you'd fetch the video metadata by ID from R2 or a DB
const title = "Vault Setup Tutorial";
---

<Layout title={`${title} | VaultHUB`}>
  <Header />
  <main class="container video-layout">
    <div class="video-main">
      <div class="video-player">
        <!-- Mock Player -->
        <div class="player-aspect">
          <div class="player-placeholder">
            <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="var(--accent-color)"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
          </div>
        </div>
      </div>
      
      <div class="video-details">
        <h1>{title}</h1>
        <div class="stats-row">
          <span>1,234,567 views</span>
          <div class="actions">
            <button class="action-btn">
               <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"></path></svg>
               Like
            </button>
            <button class="action-btn">
               <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"></path><polyline points="16 6 12 2 8 6"></polyline><line x1="12" y1="2" x2="12" y2="15"></line></svg>
               Share
            </button>
          </div>
        </div>
        <div class="description-box">
          <p>Setup tutorial for your private R2 vault. This video covers the basics of configuration and deployment.</p>
        </div>
      </div>
    </div>

    <aside class="video-sidebar">
      <h3>Up Next</h3>
      <SideVideos currentVideoId="test" />
    </aside>
  </main>
</Layout>

<style>
  .video-layout {
    display: grid;
    grid-template-columns: 1fr 400px;
    gap: 24px;
    padding-top: 24px;
  }

  .player-aspect {
    width: 100%;
    aspect-ratio: 16/9;
    background: #000;
    border-radius: 12px;
    overflow: hidden;
    position: relative;
    border: 1px solid var(--border-color);
  }

  .player-placeholder {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .video-details {
    margin-top: 20px;
  }

  h1 {
    font-size: 20px;
    font-weight: 700;
  }

  .stats-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 10px;
    color: var(--text-muted);
    font-size: 14px;
  }

  .actions {
    display: flex;
    gap: 12px;
  }

  .action-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--secondary-bg);
    padding: 8px 16px;
    border-radius: 20px;
    font-weight: 600;
    transition: background 0.2s;
  }

  .action-btn:hover {
    background: var(--border-color);
  }

  .description-box {
    background: var(--secondary-bg);
    padding: 16px;
    border-radius: 12px;
    margin-top: 20px;
    font-size: 14px;
    line-height: 1.6;
  }

  aside h3 {
    font-size: 16px;
    margin-bottom: 16px;
  }

  @media (max-width: 1100px) {
    .video-layout {
      grid-template-columns: 1fr;
    }
  }
</style>
